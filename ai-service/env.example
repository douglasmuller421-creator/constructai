# LLM API (choose one)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# OR: OpenRouter (supports Claude, Gemini, etc.)
OPENROUTER_API_KEY=sk-or-...
OPENAI_MODEL=google/gemini-2.0-flash-001

# Database (for saving estimates)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/construction_mvp

# Service
MAX_TOKENS=2048
TEMPERATURE=1.0